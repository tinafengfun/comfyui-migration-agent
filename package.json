{
  "name": "comfy-xpu-migration-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:api:demo": "MIGRATION_AGENT_DOWNLOAD_PROFILE=demo tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "tsx src/server/index.ts",
    "restart": "bash scripts/restart.sh",
    "start:proxy": "tsx src/server/deepseekProxy.ts",
    "start:demo": "MIGRATION_AGENT_DOWNLOAD_PROFILE=demo tsx src/server/index.ts",
    "asset:sources": "tsx src/server/assetSourceCli.ts",
    "asset:sources:demo": "MIGRATION_AGENT_DOWNLOAD_PROFILE=demo tsx src/server/assetSourceCli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "express": "^5.2.1",
    "global-agent": "^4.1.3",
    "https-proxy-agent": "^9.0.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-resizable-panels": "^4.11.2",
    "undici": "^8.3.0",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
