# ================================================================
# ComfyUI Migration Agent — LLM Provider Configuration
# ================================================================
#
# Copy this file and edit:
#   cp env.example env
#   vim env
#
# Then start:  bash scripts/restart.sh
#
# `env` is gitignored (it holds API keys). This file is the template.
# See docs/deployment.md for the full runbook.
# ================================================================

# ── Paths on THIS host (edit to match your machine) ──────────
export COMFYUI_ROOT=/home/intel/ComfyUI          # a ComfyUI checkout with XPU torch
export MODEL_ROOTS=/home/intel/hf_models         # colon-separated model dirs

# ── Intel outbound proxy (github / npm / DeepSeek all need it) ──
export HTTPS_PROXY=http://proxy.ims.intel.com:911
export https_proxy=http://proxy.ims.intel.com:911
# Do NOT use child-prc.intel.com:912 — Fortinet blocks *.github.com TLS.

# ── Common LLM settings ──────────────────────────────────────
export COPILOT_PROVIDER_MAX_PROMPT_TOKENS=128000
export COPILOT_PROVIDER_MAX_OUTPUT_TOKENS=16000

# ╔════════════════════════════════════════════════════════════╗
# ║  Pick ONE LLM provider profile below (uncomment one block) ║
# ╚════════════════════════════════════════════════════════════╝

# ── Profile A: DeepSeek (RECOMMENDED — current production config) ──
# Routes the Copilot SDK to DeepSeek via its OpenAI-compatible endpoint.
# Most stable: no GitHub token-exchange, just an API key.
export COPILOT_PROVIDER_TYPE=openai
export COPILOT_PROVIDER_BASE_URL=https://api.deepseek.com
export COPILOT_PROVIDER_API_KEY=sk-replace-with-your-deepseek-key
export COPILOT_MODEL=deepseek-v4-flash
export COPILOT_DISABLE_REASONING=1

# ── Profile B: GitHub Copilot API ────────────────────────────
# Requires `gh auth login` (OAuth, copilot scope) on this host.
# Leave COPILOT_SDK_GH_TOKEN UNSET so the SDK uses gh auto-login
# (useLoggedInUser). Do NOT put a classic PAT (ghp_…) in
# COPILOT_SDK_GH_TOKEN — Copilot's token-exchange rejects PATs with
# `400 Personal Access Tokens are not supported for this endpoint`.
# export COPILOT_MODEL=gpt-5-mini

# ── Profile C: Intel AI Demo API ─────────────────────────────
# export COPILOT_PROVIDER_TYPE=openai
# export COPILOT_PROVIDER_BASE_URL=https://aidemo.intel.cn/v1
# export COPILOT_PROVIDER_API_KEY=your-api-key
# export COPILOT_MODEL=minimax-m2.7

# ── Profile D: OpenAI-compatible (vLLM, Ollama, etc.) ───────
# export COPILOT_PROVIDER_TYPE=openai
# export COPILOT_PROVIDER_BASE_URL=http://localhost:11434/v1
# export COPILOT_PROVIDER_API_KEY=unused
# export COPILOT_MODEL=qwen3-235b-a22b

# ── Profile E: Anthropic ─────────────────────────────────────
# export COPILOT_PROVIDER_TYPE=anthropic
# export COPILOT_PROVIDER_BASE_URL=https://api.anthropic.com
# export COPILOT_PROVIDER_API_KEY=sk-ant-xxxxx
# export COPILOT_MODEL=claude-sonnet-4-20250514

# ================================================================
# Paths & Layout (optional overrides — defaults shown)
# ================================================================
# All relative paths resolve against the project root (this repo dir).

# Per-task workspace root (each migration task gets <root>/<taskId>/)
# export DEMO_WORKSPACE_ROOT=workspaces

# Orchestrator state dir (state.json, analytics DB)
# export DEMO_STATE_ROOT=.demo-state

# Bundled prompts dir (skills + workflow docs) — defaults to repo's prompts/
# export DRAFT_DOC_ROOT=prompts

# ── Self-evolution + memory design dirs (default to <projectRoot>/<name>) ──
# export MIGRATION_RECIPES_DIR=recipes
# export MIGRATION_SCHEMAS_DIR=schemas
# export MIGRATION_PATCHES_DIR=patches
# export MIGRATION_DEBUG_ARCHIVES_DIR=debug-archives
# export MIGRATION_ANALYTICS_DB=.demo-state/analytics.sqlite

# ── Operational flags ───────────────────────────────────────
# Set to 0 to require per-action confirmation (default: auto-approve)
# export MIGRATION_AGENT_AUTO_APPROVE=1
