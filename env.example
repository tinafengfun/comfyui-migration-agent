# ================================================================
# ComfyUI Migration Agent — LLM Provider Configuration
# ================================================================
#
# Copy this file and edit:
#   cp env.example env
#   vim env
#
# Then start:  bash scripts/restart.sh
#
# ================================================================

# ── Common settings (always active) ──
export COPILOT_PROVIDER_MAX_PROMPT_TOKENS=128000
export COPILOT_PROVIDER_MAX_OUTPUT_TOKENS=16000

# ── Corporate proxy (required for GitHub Copilot API inside Intel) ──
# Use proxy.ims.intel.com:911. Do NOT use child-prc.intel.com:912 —
# that proxy blocks TLS to *.github.com (Fortinet DPI), causing
# "Failed to list models" in the Copilot CLI subprocess.
export https_proxy=http://proxy.ims.intel.com:911
export HTTPS_PROXY=http://proxy.ims.intel.com:911

# ── Profile A: GitHub Copilot API (default) ──────────────────
# Uses gh auth token automatically; no provider vars needed.
# Requires: gh auth login (with copilot scope)
# Requires: network access to api.githubcopilot.com
export COPILOT_MODEL=gpt-5-mini

# ── Profile B: Intel AI Demo API ────────────────────────────
# export COPILOT_PROVIDER_TYPE=openai
# export COPILOT_PROVIDER_BASE_URL=https://aidemo.intel.cn/v1
# export COPILOT_PROVIDER_API_KEY=your-api-key
# export COPILOT_MODEL=minimax-m2.7

# ── Profile C: OpenAI-compatible (vLLM, Ollama, etc.) ───────
# export COPILOT_PROVIDER_TYPE=openai
# export COPILOT_PROVIDER_BASE_URL=http://localhost:11434/v1
# export COPILOT_PROVIDER_API_KEY=unused
# export COPILOT_MODEL=qwen3-235b-a22b

# ── Profile D: Anthropic ────────────────────────────────────
# export COPILOT_PROVIDER_TYPE=anthropic
# export COPILOT_PROVIDER_BASE_URL=https://api.anthropic.com
# export COPILOT_PROVIDER_API_KEY=sk-ant-xxxxx
# export COPILOT_MODEL=claude-sonnet-4-20250514
