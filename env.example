# ================================================================
# ComfyUI Migration Agent — LLM Provider Configuration
# ================================================================
#
# Copy this file and edit:
#   cp env.example env
#   vim env
#
# Then start:  bash scripts/restart.sh
#
# ================================================================

# ── Common settings (always active) ──
export COPILOT_PROVIDER_MAX_PROMPT_TOKENS=128000
export COPILOT_PROVIDER_MAX_OUTPUT_TOKENS=16000

# ── Profile A: GitHub Copilot API (default) ──────────────────
# Uses gh auth token automatically; no provider vars needed.
# Requires: gh auth login (with copilot scope)
# Requires: network access to api.githubcopilot.com
export COPILOT_MODEL=gpt-5-mini

# ── Profile B: Intel AI Demo API ────────────────────────────
# export COPILOT_PROVIDER_TYPE=openai
# export COPILOT_PROVIDER_BASE_URL=https://aidemo.intel.cn/v1
# export COPILOT_PROVIDER_API_KEY=your-api-key
# export COPILOT_MODEL=minimax-m2.7

# ── Profile C: OpenAI-compatible (vLLM, Ollama, etc.) ───────
# export COPILOT_PROVIDER_TYPE=openai
# export COPILOT_PROVIDER_BASE_URL=http://localhost:11434/v1
# export COPILOT_PROVIDER_API_KEY=unused
# export COPILOT_MODEL=qwen3-235b-a22b

# ── Profile D: Anthropic ────────────────────────────────────
# export COPILOT_PROVIDER_TYPE=anthropic
# export COPILOT_PROVIDER_BASE_URL=https://api.anthropic.com
# export COPILOT_PROVIDER_API_KEY=sk-ant-xxxxx
# export COPILOT_MODEL=claude-sonnet-4-20250514

# ================================================================
# Paths & Layout
# ================================================================
# Defaults are relative to project root (the agent-demo repo dir).
# Override only if you need to relocate things to a different mount.

# Per-task workspace root (each migration task gets <root>/<taskId>/)
# export DEMO_WORKSPACE_ROOT=workspaces

# Orchestrator state dir (state.json, analytics DB)
# export DEMO_STATE_ROOT=.demo-state

# ComfyUI checkout root (where main.py lives)
# export COMFYUI_ROOT=../ComfyUI

# Bundled prompts dir (skills + workflow docs)
# export DRAFT_DOC_ROOT=prompts

# Model roots, colon-separated, scanned for ComfyUI model assets
# export MODEL_ROOTS=/home/intel/hf_models

# ── Self-evolution + memory design dirs ──────────────────────
# These default to <projectRoot>/<name>. Relocate only if you want
# them on a different volume. See docs/evolution-and-memory-design.md.

# Reusable recipes (version controlled)
# export MIGRATION_RECIPES_DIR=recipes

# JSON schemas for skill frontmatter / recipe / feedback event
# export MIGRATION_SCHEMAS_DIR=schemas

# Patch files for ComfyUI source
# export MIGRATION_PATCHES_DIR=patches

# Out-of-band debug archives (cron-pruned)
# export MIGRATION_DEBUG_ARCHIVES_DIR=debug-archives

# Analytics DB (SQLite), defaults inside DEMO_STATE_ROOT
# export MIGRATION_ANALYTICS_DB=.demo-state/analytics.sqlite

# ── Operational flags ───────────────────────────────────────
# Set to 0 to require per-action confirmation (default: auto-approve)
# export MIGRATION_AGENT_AUTO_APPROVE=1

