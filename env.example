# ================================================================
# ComfyUI Migration Agent — Configuration
# ================================================================
#
# Copy this file and edit:
#   cp env.example env
#   vim env
#
# Then start:  bash scripts/restart.sh
#
# ================================================================

# ── External dependencies (REQUIRED for standalone deployment) ──

# ComfyUI root directory — must contain main.py and a Python venv
export COMFYUI_ROOT=/path/to/ComfyUI

# ComfyUI Python venv (optional, defaults to $COMFYUI_ROOT/.venv-xpu)
# export COMFYUI_VENV=$COMFYUI_ROOT/.venv-xpu

# Model storage roots — colon-separated list of directories
export MODEL_ROOTS=/path/to/models

# ── LLM Provider settings ──

export COPILOT_PROVIDER_MAX_PROMPT_TOKENS=128000
export COPILOT_PROVIDER_MAX_OUTPUT_TOKENS=16000

# ── Profile A: DeepSeek (recommended) ────────────────────────
export COPILOT_PROVIDER_TYPE=openai
export COPILOT_PROVIDER_BASE_URL=https://api.deepseek.com
export COPILOT_PROVIDER_API_KEY=your-api-key
export COPILOT_MODEL=deepseek-v4-flash
export COPILOT_DISABLE_REASONING=1

# ── Profile B: GitHub Copilot API ────────────────────────────
# Uses gh auth token automatically; no provider vars needed.
# Requires: gh auth login (with copilot scope)
# Requires: network access to api.githubcopilot.com
# export COPILOT_MODEL=gpt-5-mini

# ── Profile C: Intel AI Demo API ────────────────────────────
# export COPILOT_PROVIDER_TYPE=openai
# export COPILOT_PROVIDER_BASE_URL=https://aidemo.intel.cn/v1
# export COPILOT_PROVIDER_API_KEY=your-api-key
# export COPILOT_MODEL=minimax-m2.7

# ── Profile D: OpenAI-compatible (vLLM, Ollama, etc.) ───────
# export COPILOT_PROVIDER_TYPE=openai
# export COPILOT_PROVIDER_BASE_URL=http://localhost:11434/v1
# export COPILOT_PROVIDER_API_KEY=unused
# export COPILOT_MODEL=qwen3-235b-a22b

# ── Profile E: Anthropic ────────────────────────────────────
# export COPILOT_PROVIDER_TYPE=anthropic
# export COPILOT_PROVIDER_BASE_URL=https://api.anthropic.com
# export COPILOT_PROVIDER_API_KEY=sk-ant-xxxxx
# export COPILOT_MODEL=claude-sonnet-4-20250514

# ── Network proxy (required in corporate environments) ────────
# export https_proxy=http://proxy.example.com:911
# export HTTPS_PROXY=http://proxy.example.com:911

# ── Agent behavior tuning (optional) ─────────────────────────
# Auto-approve all Copilot SDK permission requests (default: 1)
# export MIGRATION_AGENT_AUTO_APPROVE=1
# Step runtime limits (ms)
# export MIGRATION_AGENT_STEP_TIMEOUT_MS=1800000
# export MIGRATION_AGENT_STEP_MAX_MS=14400000
# export MIGRATION_AGENT_SDK_IDLE_TIMEOUT_MS=14400000
# Copilot CLI path (optional, auto-detected if on PATH)
# export COPILOT_CLI_PATH=/usr/local/bin/github-copilot-cli
